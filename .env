# Crystal Messenger - Production Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env file to version control

# ── SUPABASE BACKEND (Required) ────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# Create a free project at: https://supabase.com/dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── TWILIO SMS (Optional - for SMS bridge feature) ────────────────────────────
# Get these from: https://console.twilio.com/
# Optional: Only needed if you want SMS notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── WEBRTC STUN/TURN SERVERS (For P2P calls) ────────────────────────────��──────
# Free STUN server provided by Google (works for basic P2P)
STUN_SERVER=stun:stun.l.google.com:19302
# For production, use a TURN server (e.g., Twilio Network Traversal)
TURN_SERVER_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# ── AGORA (Optional - fallback calling service) ────────────────────────────────
# Get from: https://console.agora.io/
# Optional: Only needed as backup to WebRTC
AGORA_APP_ID=

# ── APP ENVIRONMENT ───────────────────────────────────────────────────────────
APP_ENV=production
API_BASE_URL=https://your-project-id.supabase.co
